generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Модель пользователя
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  phone     String   @db.VarChar(20)
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  avatar    String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses  Address[]
  cartItems  CartItem[]
  orders     Order[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// Адреса пользователей
model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  street    String   @db.VarChar(255)
  apartment String?  @db.VarChar(50)
  floor     String?  @db.VarChar(10)
  comment   String?  @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// Модель блюда
model Dish {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  description  String   @db.Text
  category     Category
  price        Decimal  @db.Decimal(10, 2)
  weight       Int
  calories     Int
  ingredients  String   @db.Text // JSON массив
  isSpicy      Boolean  @default(false)
  isVegetarian Boolean  @default(false)
  isNew        Boolean  @default(false)
  isPopular    Boolean  @default(false)
  externalId   String?  @unique @db.VarChar(100)
  source       Source?
  stock        Int      @default(100)
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  images     DishImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("dishes")
}

enum Category {
  SIGNATURE_BURGERS @map("signature-burgers")
  CLASSIC_BURGERS   @map("classic-burgers")
  CHICKEN_SIDES     @map("chicken-sides")
  FRIES_SNACKS      @map("fries-snacks")
  DRINKS_SHAKES     @map("drinks-shakes")
  DESSERTS          @map("desserts")
}

enum Source {
  MOYSKLAD @map("moysklad")
  ONEC     @map("1c")
}

// Изображения блюд
model DishImage {
  id        Int      @id @default(autoincrement())
  dishId    Int
  path      String   @db.VarChar(255)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("dish_images")
}

// Корзина
model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  dishId    Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([userId, dishId])
  @@map("cart_items")
}

// Заказы
model Order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique @db.VarChar(50)
  userId          Int
  totalAmount     Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @db.Decimal(10, 2) @default(250)
  finalAmount     Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  street          String        @db.VarChar(255)
  apartment       String?       @db.VarChar(50)
  floor           String?       @db.VarChar(10)
  addressComment  String?       @db.Text
  deliveryTime    DateTime
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  customerComment String?       @db.Text
  adminComment    String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING     @map("pending")
  CONFIRMED   @map("confirmed")
  PREPARING   @map("preparing")
  ON_THE_WAY  @map("on-the-way")
  DELIVERED   @map("delivered")
  CANCELLED   @map("cancelled")
}

enum PaymentMethod {
  CASH @map("cash")
  CARD @map("card")
}

enum PaymentStatus {
  PENDING @map("pending")
  PAID    @map("paid")
  FAILED  @map("failed")
}

// Позиции заказа
model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  dishId    Int
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish  Dish  @relation(fields: [dishId], references: [id])

  @@map("order_items")
}