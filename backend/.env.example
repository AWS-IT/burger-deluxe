# MongoDB подключение
MONGODB_URI=mongodb://localhost:27017/burger-deluxe

# JWT секретный ключ
JWT_SECRET=your-super-secure-jwt-secret-key-here

# Порт сервера
PORT=5000

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173

# Папка для загрузки файлов
UPLOAD_PATH=uploads/dishes

# Настройки для загрузки файлов
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Настройки для интеграции (пока заглушки)
MOYSKLAD_TOKEN=your-moysklad-token
MOYSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2

# 1С настройки (пока заглушки)
ONEC_BASE_URL=http://localhost:8080/ut/hs/api
ONEC_USERNAME=your-1c-username
ONEC_PASSWORD=your-1c-password